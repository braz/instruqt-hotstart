# Copy to .env (gitignored), fill in your values, then `source .env`.
#
# The `export` keyword matters: sourcing a file with plain KEY=value lines only
# sets shell variables, which are NOT visible to the CLI (a child process).
# `export` makes them part of the environment the CLI inherits.
export INSTRUQT_API_KEY=your-api-key-here
export INSTRUQT_TEAM=your-team-slug
# export INSTRUQT_ENDPOINT=https://play.instruqt.com/graphql
